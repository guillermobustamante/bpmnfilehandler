{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "bpmn-open-command-set-command-set": {
      "components": [
        {
          "entrypoint": "./lib/extensions/bpmnOpenCommandSet/BpmnOpenCommandSetCommandSet.js",
          "manifest": "./src/extensions/bpmnOpenCommandSet/BpmnOpenCommandSetCommandSet.manifest.json"
        }
      ]
    },
    "file-preview-admin-web-part": {
      "components": [
        {
