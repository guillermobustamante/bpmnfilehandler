  "requiresCustomScript": false,

  "items": {
    "OPEN_BPMN": {
      "title": { "default": "File Preview app" },
      "type": "command"
    },
    "BPMN_SETTINGS": {
      "title": { "default": "Tenant file preview settings" },
      "type": "command"
    }
  }
}
