{
  "name": "bpmn-m365-file-handler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "tsc -p tsconfig.node.json && vite build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "manifest": "node scripts/build-file-handler-manifest.mjs"
  },
  "dependencies": {
    "@azure/msal-browser": "5.14.0",
    "bpmn-js": "18.18.0",
    "express": "5.2.1",
    "helmet": "8.2.0",
    "lucide-react": "1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.0.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}

